<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <!-- Disable all logging -->
  <rules>
    <logger name="*" minlevel="Off" writeTo="null" />
  </rules>

  <targets>
    <target xsi:type="Null" name="null" />
  </targets>

</nlog>